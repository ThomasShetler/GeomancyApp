@using GeomancyWebUI.Client.Models

@if (Analysis == null)
{
    <div class="alert alert-info">No perfection analysis available.</div>
}
else
{
    <div class="perfection-analysis">
        <h3>Perfection Analysis</h3>
        
        <!-- Summary Scores -->
        <div class="score-summary mb-3">
            <div class="row">
                <div class="col-md-4">
                    <div class="card @(Analysis.TotalFavorableScore > 0 ? "border-success" : "")">
                        <div class="card-body">
                            <h5 class="card-title">Favorable Score</h5>
                            <h3 class="@(Analysis.TotalFavorableScore > 0 ? "text-success" : "")">+@Analysis.TotalFavorableScore</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card @(Analysis.TotalUnfavorableScore < 0 ? "border-danger" : "")">
                        <div class="card-body">
                            <h5 class="card-title">Unfavorable Score</h5>
                            <h3 class="@(Analysis.TotalUnfavorableScore < 0 ? "text-danger" : "")">@Analysis.TotalUnfavorableScore</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card @(Analysis.NetScore > 0 ? "border-success" : Analysis.NetScore < 0 ? "border-danger" : "border-secondary")">
                        <div class="card-body">
                            <h5 class="card-title">Net Score</h5>
                            <h3 class="@(Analysis.NetScore > 0 ? "text-success" : Analysis.NetScore < 0 ? "text-danger" : "text-secondary")">@Analysis.NetScore</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Perfections (Collapsible) -->
        <div class="accordion mb-3" id="perfectionsAccordion">
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button @(showPerfections ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#perfectionsCollapse" @onclick="() => showPerfections = !showPerfections">
                        Perfections (@Analysis.Perfections.Count)
                    </button>
                </h2>
                <div id="perfectionsCollapse" class="accordion-collapse collapse @(showPerfections ? "show" : "")">
                    <div class="accordion-body">
                        @if (Analysis.Perfections.Count == 0)
                        {
                            <p class="text-muted">No perfections found.</p>
                        }
                        else
                        {
                            @foreach (var perfection in Analysis.Perfections)
                            {
                                @if (perfection.Success)
                                {
                                    <div class="card mb-2">
                                        <div class="card-body position-relative">
                                            <!-- Score Indicator (top right) -->
                                            @if (perfection.FavorableScore != 0 || perfection.UnfavorableScore != 0)
                                            {
                                                <div class="position-absolute top-0 end-0 p-2">
                                                    @if (perfection.FavorableScore > 0)
                                                    {
                                                        <span class="badge bg-success">+@perfection.FavorableScore</span>
                                                    }
                                                    @if (perfection.UnfavorableScore < 0)
                                                    {
                                                        <span class="badge bg-danger">@perfection.UnfavorableScore</span>
                                                    }
                                                </div>
                                            }
                                            <!-- Mode with Aspect Info Combined -->
                                            <div class="perfection-mode-section mb-2">
                                                <h6 class="card-title mb-1">
                                                    @{
                                                        var companyTypeDisplay = GetCompanyTypeDisplay(perfection);
                                                        var baseMode = GetBaseModeName(perfection);
                                                    }
                                                    @if (perfection.Mode == "Company")
                                                    {
                                                        // Company mode - show company type if available
                                                        if (!string.IsNullOrEmpty(companyTypeDisplay))
                                                        {
                                                            <span class="badge bg-primary">@companyTypeDisplay</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-primary">@perfection.Mode</span>
                                                        }
                                                        // Show the base mode (Aspect, Trine, etc.) that was made through company
                                                        if (!string.IsNullOrEmpty(baseMode))
                                                        {
                                                            <span class="badge bg-info">@baseMode</span>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        // Regular mode
                                                        <span class="badge bg-primary">@perfection.Mode</span>
                                                        @if (perfection.MadeThroughCompany)
                                                        {
                                                            // Show company type when aspect is made through company
                                                            if (!string.IsNullOrEmpty(companyTypeDisplay))
                                                            {
                                                                <span class="badge bg-info">@companyTypeDisplay</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-info">Made through Company</span>
                                                            }
                                                        }
                                                    }
                                                    @if (!string.IsNullOrEmpty(perfection.AspectBetweenSignificators) && perfection.AspectBetweenSignificators != "None")
                                                    {
                                                        <span class="badge bg-info">
                                                            @perfection.AspectBetweenSignificators
                                                            @if (!string.IsNullOrEmpty(perfection.AspectDirection))
                                                            {
                                                                <text> (@perfection.AspectDirection)</text>
                                                            }
                                                        </span>
                                                    }
                                                    @if (perfection.Mode == "Aspect" && perfection.TranslatorHouse > 0)
                                                    {
                                                        <span class="badge bg-warning">Translation</span>
                                                    }
                                                </h6>
                                            </div>

                                            <!-- Translator Information (if applicable) -->
                                            @if (perfection.TranslatorHouse > 0)
                                            {
                                                <p class="mb-1 small text-muted">
                                                    <strong>Translator:</strong> House @perfection.TranslatorHouse
                                                    @if (!string.IsNullOrEmpty(perfection.TranslatorFigure))
                                                    {
                                                        <span>(@perfection.TranslatorFigure)</span>
                                                    }
                                                </p>
                                            }

                                            <!-- Notes -->
                                            @if (perfection.Notes != null && perfection.Notes.Count > 0)
                                            {
                                                <div class="notes-section mt-2">
                                                    <ul class="list-unstyled mb-0">
                                                        @foreach (var note in perfection.Notes)
                                                        {
                                                            <li class="small text-muted">
                                                                • @note
                                                            </li>
                                                        }
                                                    </ul>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-warning">
                                        <p class="mb-0">@perfection.Message</p>
                                    </div>
                                }
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Denials (Collapsible) -->
        @if (Analysis.Denials != null && Analysis.Denials.Count > 0)
        {
            <div class="accordion mb-3" id="denialsAccordion">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button @(showDenials ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#denialsCollapse" @onclick="() => showDenials = !showDenials">
                            <span class="text-warning">⚠️ Denials (@Analysis.Denials.Count)</span>
                        </button>
                    </h2>
                    <div id="denialsCollapse" class="accordion-collapse collapse @(showDenials ? "show" : "")">
                        <div class="accordion-body">
                            @foreach (var denial in Analysis.Denials)
                            {
                                @if (denial.Success)
                                {
                                    @if (denial.Mode == "None" || denial.Mode == "Impedition")
                                    {
                                        <!-- Impedition Card -->
                                        <div class="card mb-2 border-warning">
                                            <div class="card-body position-relative">
                                                <!-- Score Indicator (top right) -->
                                                @if (denial.UnfavorableScore < 0)
                                                {
                                                    <div class="position-absolute top-0 end-0 p-2">
                                                        <span class="badge bg-danger">@denial.UnfavorableScore</span>
                                                    </div>
                                                }
                                                <!-- Impedition Mode -->
                                                <div class="perfection-mode-section mb-2">
                                                    <h6 class="card-title mb-1">
                                                        <span class="badge bg-warning">Impedition</span>
                                                    </h6>
                                                </div>

                                                <!-- Notes -->
                                                @if (denial.Notes != null && denial.Notes.Count > 0)
                                                {
                                                    <div class="notes-section mt-2">
                                                        <ul class="list-unstyled mb-0">
                                                            @foreach (var note in denial.Notes)
                                                            {
                                                                <li class="small text-muted">
                                                                    • @note
                                                                </li>
                                                            }
                                                        </ul>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <!-- Regular Denial Card -->
                                        <div class="card mb-2 border-warning">
                                            <div class="card-body position-relative">
                                                <!-- Score Indicator (top right) -->
                                                @if (denial.FavorableScore != 0 || denial.UnfavorableScore != 0)
                                                {
                                                    <div class="position-absolute top-0 end-0 p-2">
                                                        @if (denial.FavorableScore > 0)
                                                        {
                                                            <span class="badge bg-success">+@denial.FavorableScore</span>
                                                        }
                                                        @if (denial.UnfavorableScore < 0)
                                                        {
                                                            <span class="badge bg-danger">@denial.UnfavorableScore</span>
                                                        }
                                                    </div>
                                                }
                                                <!-- Mode with Aspect Info Combined -->
                                                <div class="perfection-mode-section mb-2">
                                                    <h6 class="card-title mb-1">
                                                    @{
                                                        var denialCompanyTypeDisplay = GetCompanyTypeDisplay(denial);
                                                        var denialBaseMode = GetBaseModeName(denial);
                                                    }
                                                    @if (denial.Mode == "Company")
                                                    {
                                                        // Company mode - show company type if available
                                                        if (!string.IsNullOrEmpty(denialCompanyTypeDisplay))
                                                        {
                                                            <span class="badge bg-warning">@denialCompanyTypeDisplay</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-warning">@denial.Mode</span>
                                                        }
                                                        // Show the base mode (Aspect, Trine, etc.) that was made through company
                                                        if (!string.IsNullOrEmpty(denialBaseMode))
                                                        {
                                                            <span class="badge bg-danger">@denialBaseMode</span>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        // Regular mode
                                                        <span class="badge bg-warning">@denial.Mode</span>
                                                        @if (denial.MadeThroughCompany)
                                                        {
                                                            // Show company type when aspect is made through company
                                                            if (!string.IsNullOrEmpty(denialCompanyTypeDisplay))
                                                            {
                                                                <span class="badge bg-info">@denialCompanyTypeDisplay</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-info">Made through Company</span>
                                                            }
                                                        }
                                                    }
                                                    @if (!string.IsNullOrEmpty(denial.AspectBetweenSignificators) && denial.AspectBetweenSignificators != "None")
                                                    {
                                                        <span class="badge bg-danger">
                                                            @denial.AspectBetweenSignificators
                                                            @if (!string.IsNullOrEmpty(denial.AspectDirection))
                                                            {
                                                                <text> (@denial.AspectDirection)</text>
                                                            }
                                                        </span>
                                                    }
                                                    @if (denial.Mode == "Aspect" && denial.TranslatorHouse > 0)
                                                    {
                                                        <span class="badge bg-warning">Translation</span>
                                                    }
                                                </h6>
                                            </div>

                                            <!-- Translator Information (if applicable) -->
                                            @if (denial.TranslatorHouse > 0)
                                            {
                                                <p class="mb-1 small text-muted">
                                                    <strong>Translator:</strong> House @denial.TranslatorHouse
                                                    @if (!string.IsNullOrEmpty(denial.TranslatorFigure))
                                                    {
                                                        <span>(@denial.TranslatorFigure)</span>
                                                    }
                                                </p>
                                            }

                                            <!-- Notes -->
                                            @if (denial.Notes != null && denial.Notes.Count > 0)
                                            {
                                                <div class="notes-section mt-2">
                                                    <ul class="list-unstyled mb-0">
                                                        @foreach (var note in denial.Notes)
                                                        {
                                                            <li class="small text-muted">
                                                                • @note
                                                            </li>
                                                        }
                                                    </ul>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    }
                                }
                                else
                                {
                                    <div class="alert alert-warning">
                                        <p class="mb-0">@denial.Message</p>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Positive Aspects (Collapsible) -->
        <div class="accordion mb-3" id="positiveAspectsAccordion">
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button @(showPositiveAspects ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#positiveAspectsCollapse" @onclick="() => showPositiveAspects = !showPositiveAspects">
                        Positive Aspects (@Analysis.PositiveAspects.Count)
                    </button>
                </h2>
                <div id="positiveAspectsCollapse" class="accordion-collapse collapse @(showPositiveAspects ? "show" : "")">
                    <div class="accordion-body">
                        @if (Analysis.PositiveAspects.Count == 0)
                        {
                            <p class="text-muted">No positive aspects found.</p>
                        }
                        else
                        {
                            @foreach (var aspect in Analysis.PositiveAspects)
                            {
                                <div class="card mb-2 border-success @(aspect.IsMajorAspect ? "border-2" : "")">
                                    <div class="card-body position-relative">
                                        <!-- Score Indicator (top right) -->
                                        @if (aspect.FavorableScore > 0)
                                        {
                                            <div class="position-absolute top-0 end-0 p-2">
                                                <span class="badge bg-success">+@aspect.FavorableScore</span>
                                            </div>
                                        }
                                        <h6 class="card-title text-success">
                                            @aspect.AspectType
                                            @if (aspect.IsMajorAspect)
                                            {
                                                <span class="badge bg-success ms-2">Major</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary ms-2">Minor</span>
                                            }
                                        </h6>
                                        <p class="mb-1"><strong>Direction:</strong> @aspect.Direction</p>
                                        <p class="mb-1"><strong>From House @aspect.FromHouse</strong> → <strong>House @aspect.ToHouse</strong></p>
                                        @if (aspect.MadeThroughCompany)
                                        {
                                            <span class="badge bg-info">Made through Company</span>
                                        }
                                        <p class="small text-muted mt-2">@aspect.Description</p>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Negative Aspects (Collapsible) -->
        <div class="accordion mb-3" id="negativeAspectsAccordion">
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button @(showNegativeAspects ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#negativeAspectsCollapse" @onclick="() => showNegativeAspects = !showNegativeAspects">
                        Negative Aspects (@Analysis.NegativeAspects.Count)
                    </button>
                </h2>
                <div id="negativeAspectsCollapse" class="accordion-collapse collapse @(showNegativeAspects ? "show" : "")">
                    <div class="accordion-body">
                        @if (Analysis.NegativeAspects.Count == 0)
                        {
                            <p class="text-muted">No negative aspects found.</p>
                        }
                        else
                        {
                            @foreach (var aspect in Analysis.NegativeAspects)
                            {
                                <div class="card mb-2 border-danger @(aspect.IsMajorAspect ? "border-2" : "")">
                                    <div class="card-body position-relative">
                                        <!-- Score Indicator (top right) -->
                                        @if (aspect.UnfavorableScore < 0)
                                        {
                                            <div class="position-absolute top-0 end-0 p-2">
                                                <span class="badge bg-danger">@aspect.UnfavorableScore</span>
                                            </div>
                                        }
                                        <h6 class="card-title text-danger">
                                            @aspect.AspectType
                                            @if (aspect.IsMajorAspect)
                                            {
                                                <span class="badge bg-danger ms-2">Major</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary ms-2">Minor</span>
                                            }
                                        </h6>
                                        <p class="mb-1"><strong>Direction:</strong> @aspect.Direction</p>
                                        <p class="mb-1"><strong>From House @aspect.FromHouse</strong> → <strong>House @aspect.ToHouse</strong></p>
                                        @if (aspect.MadeThroughCompany)
                                        {
                                            <span class="badge bg-info">Made through Company</span>
                                        }
                                        <p class="small text-muted mt-2">@aspect.Description</p>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public PerfectionAnalysisModel? Analysis { get; set; }

    private bool showPerfections = true;
    private bool showDenials = false;
    private bool showPositiveAspects = false;
    private bool showNegativeAspects = false;

    // Get company type display name from the CompanyType property
    private string GetCompanyTypeDisplay(PerfectionModel perfection)
    {
        if (string.IsNullOrEmpty(perfection.CompanyType) || perfection.CompanyType == "None")
            return string.Empty;

        // Convert enum value to display name
        switch (perfection.CompanyType)
        {
            case "Simple":
                return "Company Simple";
            case "DemiSimple":
                return "Company Demi-Simple";
            case "Compound":
                return "Company Compound";
            case "Capitular":
                return "Company Capitular";
            default:
                return string.Empty;
        }
    }

    // Get the base mode name when made through company
    private string GetBaseModeName(PerfectionModel perfection)
    {
        if (!string.IsNullOrEmpty(perfection.BaseMode))
        {
            return perfection.BaseMode;
        }
        return string.Empty;
    }
}

