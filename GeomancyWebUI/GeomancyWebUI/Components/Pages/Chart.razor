    private async Task GenerateChartAsync()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var request = new GenerateFourFiguresRequest
            {
                House1 = new GenerateFigureRequest
                {
                    HeadLine = house1Figure.HeadLine,
                    NeckLine = house1Figure.NeckLine,
                    BodyLine = house1Figure.BodyLine,
                    FootLine = house1Figure.FootLine
                },
                House2 = new GenerateFigureRequest
                {
                    HeadLine = house2Figure.HeadLine,
                    NeckLine = house2Figure.NeckLine,
                    BodyLine = house2Figure.BodyLine,
                    FootLine = house2Figure.FootLine
                },
                House3 = new GenerateFigureRequest
                {
                    HeadLine = house3Figure.HeadLine,
                    NeckLine = house3Figure.NeckLine,
                    BodyLine = house3Figure.BodyLine,
                    FootLine = house3Figure.FootLine
                },
                House4 = new GenerateFigureRequest
                {
                    HeadLine = house4Figure.HeadLine,
                    NeckLine = house4Figure.NeckLine,
                    BodyLine = house4Figure.BodyLine,
                    FootLine = house4Figure.FootLine
                }
            };

            houseChart = await GeomancyService.GenerateChartAsync(request);
            
            // Update the interactive house figures with full data (including names) from the API response
            if (houseChart != null)
            {
                var house1FromChart = houseChart.Houses?.FirstOrDefault(h => h.HouseNumber == 1)?.Figure;
                var house2FromChart = houseChart.Houses?.FirstOrDefault(h => h.HouseNumber == 2)?.Figure;
                var house3FromChart = houseChart.Houses?.FirstOrDefault(h => h.HouseNumber == 3)?.Figure;
                var house4FromChart = houseChart.Houses?.FirstOrDefault(h => h.HouseNumber == 4)?.Figure;
                
                // Update the local figure objects with full data from API (line values should match)
                // We update properties but keep the same object reference to maintain interactivity
                if (house1FromChart != null)
                {
                    UpdateFigureFromApi(house1Figure, house1FromChart);
                }
                
                if (house2FromChart != null)
                {
                    UpdateFigureFromApi(house2Figure, house2FromChart);
                }
                
                if (house3FromChart != null)
                {
                    UpdateFigureFromApi(house3Figure, house3FromChart);
                }
                
                if (house4FromChart != null)
                {
                    UpdateFigureFromApi(house4Figure, house4FromChart);
                }
                
                // Load aspect analysis
                await LoadAspectAnalysisAsync();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error generating chart: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadAspectAnalysisAsync()
    {
        if (houseChart == null) return;
        
        try
        {
            var request = new GenerateFourFiguresRequest
            {
                House1 = new GenerateFigureRequest
                {
                    HeadLine = house1Figure.HeadLine,
                    NeckLine = house1Figure.NeckLine,
                    BodyLine = house1Figure.BodyLine,
                    FootLine = house1Figure.FootLine
                },
                House2 = new GenerateFigureRequest
                {
                    HeadLine = house2Figure.HeadLine,
                    NeckLine = house2Figure.NeckLine,
                    BodyLine = house2Figure.BodyLine,
                    FootLine = house2Figure.FootLine
                },
                House3 = new GenerateFigureRequest
                {
                    HeadLine = house3Figure.HeadLine,
                    NeckLine = house3Figure.NeckLine,
                    BodyLine = house3Figure.BodyLine,
                    FootLine = house3Figure.FootLine
                },
                House4 = new GenerateFigureRequest
                {
                    HeadLine = house4Figure.HeadLine,
                    NeckLine = house4Figure.NeckLine,
                    BodyLine = house4Figure.BodyLine,
                    FootLine = house4Figure.FootLine
                }
            };
            
            aspectAnalysis = await GeomancyService.GetAspectAnalysisAsync(request);
        }
        catch (Exception ex)
        {
            // Silently fail - aspect analysis is optional
            aspectAnalysis = null;
        }
    }

