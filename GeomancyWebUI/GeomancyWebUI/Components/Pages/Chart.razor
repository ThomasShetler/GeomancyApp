    // Helper method to get CSS class for score display
    private string GetScoreClass(int netScore)
    {
        if (netScore > 5) return "strong-positive";
        if (netScore > 0) return "moderate-positive";
        if (netScore == 0) return "neutral";
        return "negative";
    }

    // Helper method to get CSS class for aspect score display
    private string GetAspectScoreClass(int score)
    {
        if (score > 20) return "strong-positive";
        if (score > 10) return "moderate-positive";
        if (score > 0) return "weak-positive";
        if (score == 0) return "neutral";
        return "negative";
    }

    // Helper method to convert number to ordinal (1st, 2nd, 3rd, 4th)
    private string GetTriplicityOrdinal(int number)
    {
        return number switch
        {
            1 => "1st",
            2 => "2nd",
            3 => "3rd",
            4 => "4th",
            _ => number.ToString()
        };
    }

