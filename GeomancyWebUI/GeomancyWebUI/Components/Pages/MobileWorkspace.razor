    // ----- Share / Export -----

    private enum ShareToast { None, Copied, Failed }
    private enum ExportToast { None, Saved, Failed }

    private ShareToast shareToast = ShareToast.None;
    private ExportToast exportToast = ExportToast.None;
    private ExportToast copyJsonToast = ExportToast.None;

    private void TryApplySeedFromUrl()
    {
        try
        {
            var uri = new Uri(NavigationManager.Uri);
            var query = QueryHelpers.ParseQuery(uri.Query);
            if (!query.TryGetValue(ChartSeedCodec.ParamName, out var seedValues))
            {
                return;
            }
            if (!ChartSeedCodec.TryDecode(seedValues.ToString(), out var mothers))
            {
                return;
            }

            ApplyMother(house1Figure, mothers[0]);
            ApplyMother(house2Figure, mothers[1]);
            ApplyMother(house3Figure, mothers[2]);
            ApplyMother(house4Figure, mothers[3]);
        }
        catch
        {
            // Bad URL or query: leave the default chart alone.
        }
    }

    private static void ApplyMother(FigureModel target, (int Head, int Neck, int Body, int Foot) lines)
    {
        target.HeadLine = lines.Head;
        target.NeckLine = lines.Neck;
        target.BodyLine = lines.Body;
        target.FootLine = lines.Foot;
    }

    /// <summary>
    /// Build a "/workspace?seed=..." link (canonical for shareable URLs;
    /// the App.razor mobile redirect re-routes phones to /mobile while
    /// preserving the query) and copy it to the clipboard. Mobile devices
    /// can also long-press the link in chat apps to fall through to the
    /// system share sheet, so the same flow works for SMS / Signal / etc.
    /// </summary>
    private async Task CopyShareLinkAsync()
    {
        try
        {
            var sharePath = ChartSeedCodec.BuildSharePath(
                "/workspace", house1Figure, house2Figure, house3Figure, house4Figure);
            var absolute = NavigationManager.ToAbsoluteUri(sharePath).ToString();
            var ok = await JSRuntime.InvokeAsync<bool>("copyToClipboard", absolute);
            shareToast = ok ? ShareToast.Copied : ShareToast.Failed;
        }
        catch
        {
            shareToast = ShareToast.Failed;
        }
        StateHasChanged();
        _ = ResetShareToastAsync();
    }

    private async Task ResetShareToastAsync()
    {
        await Task.Delay(1800);
        shareToast = ShareToast.None;
        await InvokeAsync(StateHasChanged);
    }

    private string BuildChartJsonPayload()
    {
        var seed = ChartSeedCodec.Encode(house1Figure, house2Figure, house3Figure, house4Figure);
        var sharePath = $"/workspace?{ChartSeedCodec.ParamName}={seed}";
        var shareUrl = NavigationManager.ToAbsoluteUri(sharePath).ToString();

        var payload = new
        {
            schema = "geofancy.chart-export",
            schemaVersion = 1,
            generatedAt = DateTime.UtcNow.ToString("o"),
            appVersion = GeofancyVersion.Display,
            shareUrl,
            seed,
            mothers = new[]
            {
                SerializeMother(1, house1Figure),
                SerializeMother(2, house2Figure),
                SerializeMother(3, house3Figure),
                SerializeMother(4, house4Figure)
            },
            chart = houseChart,
            perfectionAnalysis,
            wayOfPointsAnalysis,
            aspectAnalysis
        };

        return JsonSerializer.Serialize(payload, new JsonSerializerOptions
        {
            WriteIndented = true,
            Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping,
            DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull
        });
    }

    private async Task ExportChartJsonAsync()
    {
        if (houseChart == null)
        {
            return;
        }

        try
        {
            var json = BuildChartJsonPayload();
            var stamp = DateTime.Now.ToString("yyyyMMdd-HHmmss");
            var filename = $"geofancy-chart-{stamp}.json";
            var ok = await JSRuntime.InvokeAsync<bool>(
                "downloadTextFile", filename, json, "application/json");
            exportToast = ok ? ExportToast.Saved : ExportToast.Failed;
        }
        catch
        {
            exportToast = ExportToast.Failed;
        }
        StateHasChanged();
        _ = ResetExportToastAsync();
    }

    private async Task CopyChartJsonAsync()
    {
        if (houseChart == null)
        {
            return;
        }

        try
        {
            var json = BuildChartJsonPayload();
            var ok = await JSRuntime.InvokeAsync<bool>("copyToClipboard", json);
            copyJsonToast = ok ? ExportToast.Saved : ExportToast.Failed;
        }
        catch
        {
            copyJsonToast = ExportToast.Failed;
        }
        StateHasChanged();
        _ = ResetCopyJsonToastAsync();
    }

    private async Task ResetExportToastAsync()
    {
        await Task.Delay(1800);
        exportToast = ExportToast.None;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ResetCopyJsonToastAsync()
    {
        await Task.Delay(1800);
        copyJsonToast = ExportToast.None;
        await InvokeAsync(StateHasChanged);
    }

    private static object SerializeMother(int houseNumber, FigureModel f) => new
    {
        houseNumber,
        houseName = houseNames.TryGetValue(houseNumber, out var n) ? n : $"House {houseNumber}",
        figureName = string.IsNullOrEmpty(f.Name) ? null : f.Name,
        lines = new
        {
            head = f.HeadLine,
            neck = f.NeckLine,
            body = f.BodyLine,
            foot = f.FootLine
        }
    };

    public ValueTask DisposeAsync()
    {
        ThemeService.ThemeChanged -= OnThemeChanged;
        return ValueTask.CompletedTask;
    }
