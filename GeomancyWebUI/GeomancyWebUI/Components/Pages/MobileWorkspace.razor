@page "/mobile"
@using System.Text.Json
@using GeomancyApp
@using GeomancyWebUI.Client.Components
@using GeomancyWebUI.Client.Models
@using GeomancyWebUI.Client.Services
@using GeomancyWebUI.Components
@using GeomancyWebUI.Components.Workspace
@using GeomancyWebUI.Services
@using Microsoft.AspNetCore.WebUtilities
@inject IGeomancyService GeomancyService
@inject ThemeService ThemeService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable
@rendermode InteractiveServer

@*
    Mobile-friendly workspace at /mobile.

    Reuses every component built for the desktop /workspace page (ChartSurface,
    CourtAndHousesTab + FigureDetailPanel, PerfectionsListTab + PerfectionDetailPanel,
    WayOfPointsListTab + WayOfPointsDetailPanel) but stacks them vertically and
    adds a list-vs-detail flip inside a single mobile-panel. The desktop page is
    not touched.

    Layout (top -> bottom):
      1. mobile-chart-drawer    -> thin always-visible "Show/Hide chart" handle. The
                                   chart body is mounted as an absolute overlay
                                   underneath the handle so it slides over the
                                   tabstrip + panel without reflowing them.
      2. mobile-tabstrip        -> horizontally scrollable tab buttons. Tapping any
                                   tab also collapses the chart drawer so the panel
                                   gets full real estate.
      3. mobile-panel           -> grows to fill remaining height, scrolls internally;
                                   shows the active tab's list view by default and flips
                                   to a detail view when the user picks an item, with a
                                   sticky "Back to list" header to return.
*@

<PageTitle>Geofancy - Mobile</PageTitle>

<div class="mobile-shell">
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mobile-alert">@errorMessage</div>
    }

    <!--
        1) Chart drawer.

        The handle is always rendered and pinned at the top of the shell.
        The body is kept in the DOM whether expanded or collapsed (so the
        ChartSurface circuit doesn't tear down on toggle) and is shown /
        hidden via the .is-expanded / .is-collapsed class on the wrapper.
        When expanded the body sits absolutely-positioned over the tabstrip
        and panel as an overlay - tapping the handle dismisses it without
        reflowing the analysis area.
    -->
    <div class="mobile-chart-drawer @(chartCollapsed ? "is-collapsed" : "is-expanded")">
        <button type="button"
                class="mobile-chart-handle"
                @onclick="ToggleChartCollapsed"
                aria-expanded="@((!chartCollapsed).ToString().ToLower())"
                title="@(chartCollapsed ? "Show chart" : "Hide chart and show details")">
            <span class="handle-grip"></span>
            <span class="handle-label">
                @(chartCollapsed ? "Show chart" : "Hide chart \u00B7 Show details")
            </span>
            <span class="handle-chevron">@(chartCollapsed ? "v" : "^")</span>
        </button>

        <div class="mobile-chart-body" aria-hidden="@chartCollapsed.ToString().ToLower()">
            <div class="mobile-chart-toolbar">
                <button type="button"
                        class="mobile-pill-btn"
                        @onclick="ToggleChartType"
                        title="Switch between the shield chart and the traditional 12-house chart">
                    Switch Chart Type
                </button>
                <span class="mobile-chart-type-label">@CurrentChartTypeLabel</span>
                <button type="button"
                        class="mobile-pill-btn mobile-share-btn"
                        @onclick="CopyShareLinkAsync"
                        title="Copy a shareable link that re-creates this exact chart">
                    @(shareToast == ShareToast.Copied ? "Copied!"
                        : shareToast == ShareToast.Failed ? "Couldn't copy"
                        : "Share")
                </button>
            </div>

            <div class="mobile-chart-stage">
                <ChartSurface Chart="@houseChart"
                              House1Figure="@house1Figure"
                              House2Figure="@house2Figure"
                              House3Figure="@house3Figure"
                              House4Figure="@house4Figure"
                              OnHouse1Changed="OnHouse1Changed"
                              OnHouse2Changed="OnHouse2Changed"
                              OnHouse3Changed="OnHouse3Changed"
                              OnHouse4Changed="OnHouse4Changed"
                              View="@chartView" />
            </div>

            <!--
                Four compact Mother input cells, displayed left -> right as
                houses 4, 3, 2, 1 (the same right-to-left reading order
                that the in-chart Mother row uses). Sits below the chart so
                the chart stays the visual focus when the drawer opens and
                the user's thumb naturally lands on the inputs. Each cell
                hosts the same FigureContainer the chart uses, bound to the
                same houseNFigure instance and the same OnHouseNChanged
                handler - so taps here and taps on the chart mutate identical
                state and trigger the same regeneration pipeline.

                Labels are pulled from the houseNames dictionary in code
                (Vita / Lucrum / Fratres / Genitor) so the strip stays in
                sync with any future renames in one place.
            -->
            <div class="mobile-mother-inputs"
                 role="group"
                 aria-label="Set the four Mothers">
                <div class="mobile-mother-cell">
                    <div class="mobile-mother-label" title="House 4 - @houseNames[4]">
                        4. @houseNames[4]
                    </div>
                    <div class="mobile-mother-figure">
                        <FigureContainer Figure="@house4Figure"
                                         IsInteractive="true"
                                         ShowFigureName="true"
                                         ShowHouseStrength="false"
                                         OnFigureChanged="OnHouse4Changed" />
                    </div>
                </div>
                <div class="mobile-mother-cell">
                    <div class="mobile-mother-label" title="House 3 - @houseNames[3]">
                        3. @houseNames[3]
                    </div>
                    <div class="mobile-mother-figure">
                        <FigureContainer Figure="@house3Figure"
                                         IsInteractive="true"
                                         ShowFigureName="true"
                                         ShowHouseStrength="false"
                                         OnFigureChanged="OnHouse3Changed" />
                    </div>
                </div>
                <div class="mobile-mother-cell">
                    <div class="mobile-mother-label" title="House 2 - @houseNames[2]">
                        2. @houseNames[2]
                    </div>
                    <div class="mobile-mother-figure">
                        <FigureContainer Figure="@house2Figure"
                                         IsInteractive="true"
                                         ShowFigureName="true"
                                         ShowHouseStrength="false"
                                         OnFigureChanged="OnHouse2Changed" />
                    </div>
                </div>
                <div class="mobile-mother-cell">
                    <div class="mobile-mother-label" title="House 1 - @houseNames[1]">
                        1. @houseNames[1]
                    </div>
                    <div class="mobile-mother-figure">
                        <FigureContainer Figure="@house1Figure"
                                         IsInteractive="true"
                                         ShowFigureName="true"
                                         ShowHouseStrength="false"
                                         OnFigureChanged="OnHouse1Changed" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 2) Horizontal tab strip -->
    <nav class="mobile-tabstrip" role="tablist">
        @foreach (var tab in Tabs)
        {
            <button type="button"
                    role="tab"
                    class="mobile-tab-btn @(activeTab == tab.Id ? "active" : "")"
                    @onclick="() => SwitchTab(tab.Id)">
                @tab.Label
            </button>
        }
    </nav>

    <!-- 3) Detail / list panel -->
    <section class="mobile-panel" role="tabpanel">
        @if (panelMode == MobilePanelMode.Detail && CurrentTabSupportsDetail())
        {
            <header class="mobile-panel-back" @onclick="ShowList" role="button" tabindex="0">
                <span class="back-chevron">&lsaquo;</span>
                <span class="back-label">Back to @ActiveTabLabel list</span>
            </header>
        }

        <div class="mobile-panel-body">
            @switch (activeTab)
            {
                case WorkspaceTab.CourtAndHouses:
                    @if (panelMode == MobilePanelMode.List)
                    {
                        <CourtAndHousesTab Chart="@houseChart"
                                           Selected="@selectedSlot"
                                           HousesDirectory="@housesDirectory"
                                           CourtsDirectory="@courtsDirectory"
                                           OnSelect="OnSlotSelected" />
                    }
                    else
                    {
                        <FigureDetailPanel Selection="@selectedSlot"
                                           Houses="@housesDirectory"
                                           Courts="@courtsDirectory" />
                    }
                    break;

                case WorkspaceTab.PerfectionsAndAspects:
                    @if (panelMode == MobilePanelMode.List)
                    {
                        <PerfectionsListTab Chart="@houseChart"
                                            Analysis="@perfectionAnalysis"
                                            QuerentHouse="@selectedQuerentHouse"
                                            QuesitedHouse="@selectedQuesitedHouse"
                                            HouseOptions="@GetHouseOptions()"
                                            Selected="@selectedPerfection"
                                            OnQuerentChanged="OnQuerentSelectChanged"
                                            OnQuesitedChanged="OnQuesitedSelectChanged"
                                            OnSelect="OnPerfectionSelected" />
                    }
                    else
                    {
                        <PerfectionDetailPanel Selection="@selectedPerfection"
                                               Analysis="@perfectionAnalysis" />
                    }
                    break;

                case WorkspaceTab.WayOfPoints:
                    @if (panelMode == MobilePanelMode.List)
                    {
                        <WayOfPointsListTab Analysis="@wayOfPointsAnalysis"
                                            Chart="@houseChart"
                                            Elements="@wayOfPointsElements"
                                            PathTypes="@wayOfPointsPathTypes"
                                            Selected="@selectedWayOfPoints"
                                            OnSelect="OnWayOfPointsSelected" />
                    }
                    else
                    {
                        <WayOfPointsDetailPanel Selection="@selectedWayOfPoints"
                                                Chart="@houseChart"
                                                Elements="@wayOfPointsElements"
                                                PathTypes="@wayOfPointsPathTypes" />
                    }
                    break;

                case WorkspaceTab.Triplicates:
                    @if (houseChart?.Triplicities != null && houseChart.Triplicities.Any())
                    {
                        <ul class="mobile-triplicities-list">
                            @foreach (var t in houseChart.Triplicities.OrderBy(x => x.Number))
                            {
                                <li class="mobile-triplicity-item">
                                    <div class="mobile-triplicity-header">
                                        <span class="mobile-triplicity-number">@GetTriplicityOrdinal(t.Number):</span>
                                        @if (!string.IsNullOrEmpty(t.Description))
                                        {
                                            <span class="mobile-triplicity-description">@t.Description</span>
                                        }
                                    </div>
                                    <span class="mobile-triplicity-figures">
                                        @(t.FirstFigure?.Name ?? "N/A") &gt; @(t.SecondFigure?.Name ?? "N/A") &gt; @(t.ThirdFigure?.Name ?? "N/A")
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="mobile-empty">No triplicities available.</p>
                    }
                    break;

                case WorkspaceTab.LotsAndOther:
                    <div class="mobile-experimental-section">
                        <section class="mobile-subsection mobile-chart-export-section">
                            <div class="mobile-chart-export-header">
                                <h3>Export chart</h3>
                            </div>
                            <p class="mobile-chart-export-help">
                                Download or copy the full reading - the four Mothers, the resolved
                                chart, the perfection analysis, and the Way of Points result - as a
                                single JSON object for archiving or sharing.
                            </p>
                            <div class="mobile-chart-export-actions">
                                <button type="button"
                                        class="mobile-pill-btn"
                                        @onclick="CopyChartJsonAsync"
                                        disabled="@(houseChart == null)"
                                        title="Copy this reading to the clipboard as JSON">
                                    @(copyJsonToast == ExportToast.Saved ? "Copied!"
                                        : copyJsonToast == ExportToast.Failed ? "Couldn't copy"
                                        : "Copy JSON")
                                </button>
                                <button type="button"
                                        class="mobile-pill-btn"
                                        @onclick="ExportChartJsonAsync"
                                        disabled="@(houseChart == null)"
                                        title="Save this reading as a JSON file">
                                    @(exportToast == ExportToast.Saved ? "Saved!"
                                        : exportToast == ExportToast.Failed ? "Couldn't save"
                                        : "Download JSON")
                                </button>
                            </div>
                        </section>

                        <div class="mobile-experimental-banner">
                            <span class="mobile-experimental-badge">Experimental</span>
                            <span class="mobile-experimental-note">
                                Replaced by the Perfection Analysis on the Perfections tab. Kept here for reference.
                            </span>
                        </div>

                        @if (aspectAnalysis != null && aspectAnalysis.Success)
                        {
                            <section class="mobile-subsection">
                                <div class="mobile-aspect-analysis-header">
                                    <h3>Aspect Analysis</h3>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleAspectAnalysisDetails">
                                        @(showAspectDetails ? "Hide details" : "Show details")
                                    </button>
                                </div>
                                <div class="mobile-aspect-summary">
                                    <div class="mobile-aspect-summary-item">
                                        <span class="label">Total Score:</span>
                                        <strong>@aspectAnalysis.TotalScore</strong>
                                    </div>
                                    <div class="mobile-aspect-summary-item">
                                        <span class="label">Total Aspects:</span>
                                        <strong>@aspectAnalysis.TotalAspects</strong>
                                    </div>
                                    @if (aspectAnalysis.Polarity != null)
                                    {
                                        <div class="mobile-aspect-summary-item">
                                            <span class="label">Polarity:</span>
                                            <strong>@aspectAnalysis.Polarity.Verdict (@aspectAnalysis.Polarity.Percent.ToString("F1")%)</strong>
                                        </div>
                                    }
                                </div>
                                @if (showAspectDetails)
                                {
                                    @if (aspectAnalysis.AspectCounts != null && aspectAnalysis.AspectCounts.Any())
                                    {
                                        <div>
                                            <h5>Aspect Counts</h5>
                                            <ul>
                                                @foreach (var c in aspectAnalysis.AspectCounts)
                                                {
                                                    <li><strong>@c.Key:</strong> @c.Value</li>
                                                }
                                            </ul>
                                        </div>
                                    }
                                    @if (aspectAnalysis.Aspects != null && aspectAnalysis.Aspects.Any())
                                    {
                                        <div>
                                            <h5>All Aspects (@aspectAnalysis.Aspects.Count)</h5>
                                            @foreach (var a in aspectAnalysis.Aspects)
                                            {
                                                <div class="mobile-aspect-row">
                                                    <span>House @a.FromHouse &rarr; House @a.ToHouse</span>
                                                    <span>@a.AspectType</span>
                                                    <span>Weight: @a.Weight</span>
                                                    <span>@a.FromFigure &rarr; @a.ToFigure</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                            </section>
                        }
                        else
                        {
                            <p class="mobile-empty">Aspect analysis is loading...</p>
                        }
                    </div>
                    break;
            }
        </div>
    </section>
</div>

@code {
    // ----- Chart state -----
    private HouseChartModel? houseChart;
    private string errorMessage = string.Empty;

    private FigureModel house1Figure = new() { HeadLine = 2, NeckLine = 2, BodyLine = 2, FootLine = 2 };
    private FigureModel house2Figure = new() { HeadLine = 2, NeckLine = 2, BodyLine = 2, FootLine = 2 };
    private FigureModel house3Figure = new() { HeadLine = 2, NeckLine = 2, BodyLine = 2, FootLine = 2 };
    private FigureModel house4Figure = new() { HeadLine = 2, NeckLine = 2, BodyLine = 2, FootLine = 2 };

    // ----- View toggles -----
    private ChartSurfaceView chartView = ChartSurfaceView.Shield;

    private string CurrentChartTypeLabel => chartView switch
    {
        ChartSurfaceView.Shield => "Shield Chart",
        ChartSurfaceView.House => "12-House Chart",
        _ => "Both"
    };

    // ----- Tab state -----
    private enum WorkspaceTab
    {
        CourtAndHouses,
        PerfectionsAndAspects,
        WayOfPoints,
        Triplicates,
        LotsAndOther
    }

    private record TabDef(WorkspaceTab Id, string Label);

    private static readonly TabDef[] Tabs = new[]
    {
        new TabDef(WorkspaceTab.CourtAndHouses, "Court & Houses"),
        new TabDef(WorkspaceTab.PerfectionsAndAspects, "Perfections & Aspects"),
        new TabDef(WorkspaceTab.WayOfPoints, "Way Of Points"),
        new TabDef(WorkspaceTab.Triplicates, "Triplicates"),
        new TabDef(WorkspaceTab.LotsAndOther, "Lots & Other")
    };

    private WorkspaceTab activeTab = WorkspaceTab.CourtAndHouses;

    // ----- Mobile-only panel mode -----
    // List shows the tab's list/summary view; Detail shows the picked item
    // taking over the panel. Switching tabs always returns to List.
    private enum MobilePanelMode { List, Detail }
    private MobilePanelMode panelMode = MobilePanelMode.List;

    // ----- Chart drawer state -----
    // Chart starts visible (the user just generated a reading, so seeing it
    // matters), but auto-collapses the moment they tap into a tab so the
    // analysis area gets full real estate. The drawer handle remains pinned
    // to the top so the chart is always one tap away as an overlay.
    private bool chartCollapsed = false;

    private void ToggleChartCollapsed() => chartCollapsed = !chartCollapsed;

    private string ActiveTabLabel
        => Tabs.FirstOrDefault(t => t.Id == activeTab)?.Label ?? string.Empty;

    private bool CurrentTabSupportsDetail()
        => activeTab is WorkspaceTab.CourtAndHouses
                     or WorkspaceTab.PerfectionsAndAspects
                     or WorkspaceTab.WayOfPoints;

    private void SwitchTab(WorkspaceTab tab)
    {
        activeTab = tab;
        // Always return to the list view when switching tabs so the user
        // doesn't land on an unrelated tab's detail snapshot.
        panelMode = MobilePanelMode.List;
        // Tapping a tab is the user's signal that they want to focus on the
        // analysis. Collapse the chart drawer so the panel gets full height;
        // they can pull it back as an overlay any time via the handle.
        chartCollapsed = true;
    }

    private void ShowList() => panelMode = MobilePanelMode.List;

    // ----- Selection state shared between list and detail panel -----
    private SlotSelection? selectedSlot;
    private PerfectionSelection? selectedPerfection;
    private WayOfPointsSelection? selectedWayOfPoints;

    // ----- Reference directories -----
    private List<HouseDirectoryEntry> housesDirectory = new();
    private List<CourtDirectoryEntry> courtsDirectory = new();
    private List<WayOfPointsElementEntry>? wayOfPointsElements;
    private List<WayOfPointsPathTypeEntry>? wayOfPointsPathTypes;

    // ----- Analysis state (Perfections / Aspects / Way of Points) -----
    private int selectedQuerentHouse = 0;
    private int selectedQuesitedHouse = 0;
    private PerfectionAnalysisModel? perfectionAnalysis;
    private AspectAnalysisModel? aspectAnalysis;
    private WayOfPointsAnalysisModel? wayOfPointsAnalysis;
    private bool showAspectDetails = false;

    private static readonly Dictionary<int, string> houseNames = new()
    {
        { 1, "Vita" }, { 2, "Lucrum" }, { 3, "Fratres" }, { 4, "Genitor" },
        { 5, "Nati" }, { 6, "Valetudo" }, { 7, "Uxor" }, { 8, "Mors" },
        { 9, "Itineris" }, { 10, "Regnum" }, { 11, "Benefacta" }, { 12, "Carcer" }
    };

    protected override async Task OnInitializedAsync()
    {
        ThemeService.ThemeChanged += OnThemeChanged;

        // If the user followed a "?seed=..." share link (typically from a
        // /workspace URL that the App.razor redirect bumped to /mobile,
        // preserving the query string), hydrate the four Mothers from it
        // before the first chart generation so the page renders the shared
        // reading on first paint.
        TryApplySeedFromUrl();

        try
        {
            await GenerateChartAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error initializing workspace chart: {ex.Message}";
        }

        try
        {
            housesDirectory = await GeomancyService.GetHousesDirectoryAsync();
            courtsDirectory = await GeomancyService.GetCourtsDirectoryAsync();
        }
        catch (Exception ex)
        {
            errorMessage = string.IsNullOrEmpty(errorMessage)
                ? $"Reference directory unavailable: {ex.Message}"
                : errorMessage;
        }

        try
        {
            wayOfPointsElements = await GeomancyService.GetWayOfPointsElementsDirectoryAsync();
            wayOfPointsPathTypes = await GeomancyService.GetWayOfPointsPathTypesDirectoryAsync();
        }
        catch (Exception ex)
        {
            errorMessage = string.IsNullOrEmpty(errorMessage)
                ? $"Way of Points directory unavailable: {ex.Message}"
                : errorMessage;
        }
    }

    private void ToggleChartType()
    {
        chartView = chartView == ChartSurfaceView.Shield
            ? ChartSurfaceView.House
            : ChartSurfaceView.Shield;
    }

    // ----- Selection handlers (auto-flip the panel into Detail mode) -----
    private void OnSlotSelected(SlotSelection selection)
    {
        selectedSlot = selection;
        panelMode = MobilePanelMode.Detail;
    }

    private void OnPerfectionSelected(PerfectionSelection selection)
    {
        selectedPerfection = selection;
        panelMode = MobilePanelMode.Detail;
    }

    private void OnWayOfPointsSelected(WayOfPointsSelection selection)
    {
        selectedWayOfPoints = selection;
        panelMode = MobilePanelMode.Detail;
    }

    private async Task OnQuerentSelectChanged(int n)
    {
        selectedQuerentHouse = n;
        selectedPerfection = null;
        await OnQuerentChanged();
    }

    private async Task OnQuesitedSelectChanged(int n)
    {
        selectedQuesitedHouse = n;
        selectedPerfection = null;
        await OnQuesitedChanged();
    }

    private List<(int Number, string DisplayText)> GetHouseOptions()
    {
        var options = new List<(int, string)>();
        for (var i = 1; i <= 12; i++)
        {
            var figure = houseChart?.Houses?.FirstOrDefault(h => h.HouseNumber == i)?.Figure;
            var name = houseNames.TryGetValue(i, out var n) ? n : $"House {i}";
            var figureName = figure?.Name ?? "N/A";
            options.Add((i, $"House {i} ({name}): {figureName}"));
        }
        return options;
    }

    private static string GetTriplicityOrdinal(int n) => n switch
    {
        1 => "1st", 2 => "2nd", 3 => "3rd", 4 => "4th",
        _ => n.ToString()
    };

    private async Task OnQuerentChanged()
    {
        if (selectedQuerentHouse > 0 && selectedQuesitedHouse > 0)
        {
            await CalculatePerfectionAsync();
        }
    }

    private async Task OnQuesitedChanged()
    {
        if (selectedQuerentHouse > 0 && selectedQuesitedHouse > 0)
        {
            await CalculatePerfectionAsync();
        }
    }

    private void ToggleAspectAnalysisDetails() => showAspectDetails = !showAspectDetails;

    private async Task CalculatePerfectionAsync()
    {
        if (houseChart == null || selectedQuerentHouse == 0 || selectedQuesitedHouse == 0)
        {
            perfectionAnalysis = null;
            selectedPerfection = null;
            return;
        }

        try
        {
            var request = new PerfectionRequestModel
            {
                Mothers = BuildFourFiguresRequest(),
                QuerentHouse = selectedQuerentHouse,
                QuesitedHouse = selectedQuesitedHouse
            };
            perfectionAnalysis = await GeomancyService.AnalyzePerfectionsAsync(request);
            selectedPerfection = null;
        }
        catch (Exception ex)
        {
            perfectionAnalysis = new PerfectionAnalysisModel
            {
                Success = false,
                Message = $"Error analyzing perfections: {ex.Message}"
            };
            selectedPerfection = null;
        }
    }

    private async Task LoadAspectAnalysisAsync()
    {
        if (houseChart == null) return;
        try
        {
            aspectAnalysis = await GeomancyService.GetAspectAnalysisAsync(BuildFourFiguresRequest());
        }
        catch
        {
            aspectAnalysis = null;
        }
    }

    private async Task LoadWayOfPointsAsync()
    {
        if (houseChart == null) return;
        try
        {
            wayOfPointsAnalysis = await GeomancyService.CalculateWayOfPointsAsync(BuildFourFiguresRequest());
        }
        catch
        {
            wayOfPointsAnalysis = null;
        }
        selectedWayOfPoints = null;
    }

    private async Task GenerateChartAsync()
    {
        errorMessage = string.Empty;

        try
        {
            var request = BuildFourFiguresRequest();
            houseChart = await GeomancyService.GenerateChartAsync(request);

            if (houseChart != null)
            {
                SyncMotherFromChart(1, house1Figure);
                SyncMotherFromChart(2, house2Figure);
                SyncMotherFromChart(3, house3Figure);
                SyncMotherFromChart(4, house4Figure);

                if (selectedSlot != null)
                {
                    selectedSlot = ResolveSelection(selectedSlot);
                }

                await LoadAspectAnalysisAsync();
                await LoadWayOfPointsAsync();
                if (selectedQuerentHouse > 0 && selectedQuesitedHouse > 0)
                {
                    await CalculatePerfectionAsync();
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error generating chart: {ex.Message}";
        }
    }

    private GenerateFourFiguresRequest BuildFourFiguresRequest() => new()
    {
        House1 = ToFigureRequest(house1Figure),
        House2 = ToFigureRequest(house2Figure),
        House3 = ToFigureRequest(house3Figure),
        House4 = ToFigureRequest(house4Figure)
    };

    private static GenerateFigureRequest ToFigureRequest(FigureModel f) => new()
    {
        HeadLine = f.HeadLine,
        NeckLine = f.NeckLine,
        BodyLine = f.BodyLine,
        FootLine = f.FootLine
    };

    private void SyncMotherFromChart(int houseNumber, FigureModel target)
    {
        var source = houseChart?.Houses?.FirstOrDefault(h => h.HouseNumber == houseNumber)?.Figure;
        if (source == null) return;

        target.Name = source.Name ?? string.Empty;
        target.OtherNames = source.OtherNames ?? string.Empty;
        target.Quality = source.Quality ?? string.Empty;
        target.Keyword = source.Keyword ?? string.Empty;
        target.Imagery = source.Imagery ?? string.Empty;
        target.StrongHouse = source.StrongHouse ?? string.Empty;
        target.WeakHouse = source.WeakHouse ?? string.Empty;
        target.Planet = source.Planet ?? string.Empty;
        target.Sign = source.Sign ?? string.Empty;
        target.InnerEl = source.InnerEl ?? string.Empty;
        target.OuterEl = source.OuterEl ?? string.Empty;
        target.FireElement = source.FireElement ?? string.Empty;
        target.AirElement = source.AirElement ?? string.Empty;
        target.WaterElement = source.WaterElement ?? string.Empty;
        target.EarthElement = source.EarthElement ?? string.Empty;
        target.Anatomy = source.Anatomy ?? string.Empty;
        target.BodyType = source.BodyType ?? string.Empty;
        target.CharacterType = source.CharacterType ?? string.Empty;
        target.Colors = source.Colors ?? string.Empty;
        target.Commentary = source.Commentary ?? string.Empty;
        target.DivinatoryMeaning = source.DivinatoryMeaning ?? string.Empty;
        target.ElementalPattern = source.ElementalPattern ?? string.Empty;
        target.HouseStrength = source.HouseStrength;
    }

    private SlotSelection ResolveSelection(SlotSelection prior)
    {
        FigureModel? figure = prior.Kind switch
        {
            SlotKind.House when prior.HouseNumber.HasValue
                => houseChart?.Houses?.FirstOrDefault(h => h.HouseNumber == prior.HouseNumber.Value)?.Figure,
            SlotKind.RightWitness => houseChart?.RightWitness,
            SlotKind.LeftWitness => houseChart?.LeftWitness,
            SlotKind.Judge => houseChart?.Judge,
            SlotKind.Sentence => houseChart?.Sentence,
            _ => prior.Figure
        };
        return prior with { Figure = figure };
    }

