@using System.Text.RegularExpressions
@using GeomancyWebUI.Client.Models

@*
    Right-column detail panel for the revamped Way Of Points tab.

    Renders structured detail for whichever entry was clicked on the left.
      - When `Selection.Path` is null we render the whole-Way summary
        (element header, glossary tagline, established/not chip,
        element-interpretation tip stack, raw notes). No Mechanism card:
        that copy was path-gating language and read as "not established"
        even when the way was open.
      - When `Selection.Path` is non-null we render the path-type label,
        mechanism graph (Judge -> Witness -> Niece -> endpoint with figure
        names), and the path-type interpretation tip stack.

    The panel itself is the only scroll container in the right column.
*@

<div class="wop-detail-panel @(Selection == null ? "is-empty" : "")"
     style="@PanelStyle()">
    @if (Selection == null)
    {
        <div class="wop-detail-empty">
            <p>Select an element or path on the left to see its details.</p>
        </div>
    }
    else
    {
        var elementKey = Selection.ElementId;
        var entry = LookupElement(elementKey);
        var pathTypeEntry = Selection.Path != null ? LookupPathType(Selection.Path.PathType) : null;
        var glyph = entry?.Glyph ?? FallbackGlyph(elementKey);
        var latin = entry?.LatinName ?? FallbackLatin(elementKey);
        var quality = entry?.Quality;
        var polarity = entry?.Polarity;
        var hasPath = Selection.Path != null;
        var wayOfLightPath = hasPath && Selection.Path!.IsClassicalWayOfLight;
        var fireSummaryLight = !hasPath
            && string.Equals(Selection.ElementId, "Fire", StringComparison.OrdinalIgnoreCase)
            && Selection.Way.HasClassicalWayOfLight;
        var titleText = wayOfLightPath
            ? "Way of the Light"
            : hasPath ? (pathTypeEntry?.Name ?? PathTypeFallback(Selection.Path!.PathType)) : "Way Summary";
        var endpointPill = hasPath ? EndpointPill(Selection.Path!) : (Selection.Way.CanBeEstablished ? "Established" : "Not Established");

        <header class="wop-detail-header">
            <div class="header-titles">
                <p class="kind-eyebrow">Way of Points · @elementKey</p>
                <h2 class="kind-title">
                    <span class="title-glyph">@glyph</span>
                    @titleText
                </h2>
                <p class="kind-subtitle">@latin@(string.IsNullOrEmpty(entry?.LineName) ? "" : $" · {entry!.LineName}")</p>
            </div>
            <div class="header-score-pill @(wayOfLightPath ? "pill-way-of-light" : (hasPath ? PathTypeChipClass(Selection.Path!.PathType) : (Selection.Way.CanBeEstablished ? "pill-established" : "pill-not-established")))">
                @endpointPill
            </div>
        </header>

        @if (entry != null && !string.IsNullOrEmpty(entry.Tagline))
        {
            <p class="glossary-tagline">@entry.Tagline</p>
        }

        <!-- Chip row -->
        <div class="chip-row">
            <span class="chip chip-element">
                <span class="chip-arrow">@glyph</span>@elementKey
            </span>
            @if (Selection.Way.CanBeEstablished)
            {
                <span class="chip chip-established">Established</span>
            }
            else
            {
                <span class="chip chip-not-established">Not Established</span>
            }
            @if (hasPath)
            {
                <span class="chip @PathTypeChipClass(Selection.Path!.PathType)">
                    <span class="chip-arrow">@PathTypeGlyph(Selection.Path.PathType)</span>
                    @PathTypeShort(Selection.Path.PathType)
                </span>
                <span class="chip chip-row-num">Row @Selection.Path.RowReached — @RowLabel(Selection.Path.RowReached)</span>
            }
            @if (!string.IsNullOrEmpty(quality))
            {
                <span class="chip chip-meta">@quality</span>
            }
            @if (!string.IsNullOrEmpty(polarity))
            {
                <span class="chip chip-meta">@polarity</span>
            }
            @if (wayOfLightPath || fireSummaryLight)
            {
                <span class="chip chip-way-of-light">&#9728; Way of the Light</span>
            }
        </div>

        @if (wayOfLightPath || fireSummaryLight)
        {
            <div class="way-of-light-stack" aria-label="Way of the Light reference">
                <section class="detail-card way-of-light-card">
                    <h3 class="card-title">
                        <span class="card-title-icon">&#9728;</span> How it is calculated
                    </h3>
                    <p class="wol-card-body">
                        The app flags <strong>Way of the Light</strong> only on <strong>Via Puncti Ignis</strong> (the fire / head line):
                        the Judge’s fire point must agree with both Witnesses so the way can form; there must be <strong>exactly one strong</strong> path;
                        and <strong>every figure on that path</strong> must show <strong>active fire</strong> (a single dot on the head line), not passive (double).
                        That matches a narrow classical reading of the fire way of points as a single lucid chain of “open” fire.
                    </p>
                </section>
                <section class="detail-card way-of-light-card">
                    <h3 class="card-title">
                        <span class="card-title-icon">&#9728;</span> What it signifies in a reading
                    </h3>
                    @if (wayOfLightPath)
                    {
                        <p class="wol-card-body">
                            Many geomancers treat this configuration as a bright thread through the chart: a line of agreement on fire that stays
                            <em>active</em> all the way down, often read as the <strong>heart or root of the matter</strong> showing where the
                            narrative wants to land — here at <strong>House @Selection.Path!.EndpointHouse — @GetLatinHouseName(Selection.Path.EndpointHouse)</strong>.
                            It is interpretive tradition, not a mechanical guarantee of outcome.
                        </p>
                    }
                    else
                    {
                        <p class="wol-card-body">
                            When present, the Light path is read as a concentrated clue to the <strong>heart of the matter</strong> on the fire line.
                            Select the row marked <strong>Light</strong> in the list to see the full chain and the house where this thread lands.
                        </p>
                    }
                </section>
                <section class="detail-card way-of-light-card">
                    <h3 class="card-title">
                        <span class="card-title-icon">&#9728;</span> Present vs absent
                    </h3>
                    <p class="wol-card-body">
                        <strong>Present:</strong> Fire is established in the usual way-of-points sense <em>and</em> the single strong path is entirely on active fire —
                        the app then marks that path (and the Fire summary) with Way of the Light.
                        <strong>Absent:</strong> Fire may still be “open” with passive paths, multiple strong branches, or broken active-fire continuity; those can be
                        important technically but are not labeled Light here. Absence does not erase a strong chart — it only means this particular classical spotlight does not apply.
                    </p>
                </section>
                <section class="detail-card way-of-light-card">
                    <h3 class="card-title">
                        <span class="card-title-icon">&#9728;</span> House as core of the matter
                    </h3>
                    @if (wayOfLightPath)
                    {
                        <p class="wol-card-body">
                            The endpoint house names where the active-fire chain <strong>grounds in the wheel</strong> — the topical house at the end of the path.
                            Readers often weigh that house’s figure and dignities when asking “where does the matter root?” alongside the Judge and the querent’s houses.
                            Row depth (how far the path reaches) still matters for how loudly that house speaks in the story.
                        </p>
                    }
                    else
                    {
                        <p class="wol-card-body">
                            Open the <strong>Light</strong> path row to see which house receives the endpoint; that house is the usual anchor for “root of the matter”
                            language in this classical fire reading.
                        </p>
                    }
                </section>
                <section class="detail-card way-of-light-card">
                    <h3 class="card-title">
                        <span class="card-title-icon">&#9728;</span> Blockages, hidden links, paths forward
                    </h3>
                    <p class="wol-card-body">
                        In practice, readers use the Light chain to ask where momentum stays <em>unbroken</em> on fire — sometimes read as clarity, candor, or a visible through-line
                        in an otherwise tangled chart. It can highlight where resistance is <strong>not</strong> damping the fire line, or where a hidden linkage runs alongside
                        a noisier perfection. Treat these as narrative prompts to interrogate the figures involved, not as automatic “yes” or “no” verdicts.
                    </p>
                </section>
                <section class="detail-card way-of-light-card">
                    <h3 class="card-title">
                        <span class="card-title-icon">&#9728;</span> How this differs from the four elemental ways
                    </h3>
                    <p class="wol-card-body">
                        The ordinary <strong>Way of Points</strong> inspects all four elemental lines (fire, air, water, earth): each can open or close on its own pattern of
                        strong and passive paths. <strong>Way of the Light</strong> is a <em>special case on fire only</em> — one strong path, continuous active head-line fire —
                        borrowed from classical emphasis on the via punctorum ignis. The app name <strong>Way of the Light</strong> reflects that restriction: in traditional
                        dot language, “active” fire reads as a single bright point on the line, so the image is literally a thread of lights through the tree.
                    </p>
                </section>
            </div>
        }

        @* Mechanism card only when a specific path is selected (graph + endpoint). *@
        @if (hasPath)
        {
            <section class="detail-card mechanism-card">
                <h3 class="card-title">
                    <span class="card-title-icon">⚙</span> Mechanism
                </h3>
                <div class="mechanism-graph @(wayOfLightPath ? "is-way-of-light-graph" : "")">
                    @{
                        var nodes = BuildPathNodes(Selection.Path!);
                    }
                    @for (var i = 0; i < nodes.Count; i++)
                    {
                        var node = nodes[i];
                        <div class="mech-node @node.Css">
                            <span class="mech-node-eyebrow">@node.Role</span>
                            <span class="mech-node-title">@node.Position</span>
                            @if (!string.IsNullOrEmpty(node.Figure))
                            {
                                <span class="mech-node-figure">@node.Figure</span>
                            }
                        </div>
                        @if (i < nodes.Count - 1)
                        {
                            <span class="mech-arrow">›</span>
                        }
                    }
                </div>
                <p class="mechanism-tail">
                    Endpoint <strong>House @Selection.Path!.EndpointHouse — @GetLatinHouseName(Selection.Path.EndpointHouse)</strong>
                    on Row @Selection.Path.RowReached.
                    @if (wayOfLightPath)
                    {
                        <span class="way-of-light-tail-note"> Active fire (single dot) is maintained from Judge through this chain.</span>
                    }
                </p>
            </section>
        }

        @* Element interpretation tip stack — same visual vocabulary as
           PerfectionDetailPanel's interpretation tips. *@
        @if (entry != null && entry.InterpretationParagraphs.Count > 0)
        {
            <section class="detail-card interpretation-card">
                <h3 class="card-title">
                    <span class="card-title-icon">✦</span> Element Interpretation
                </h3>
                <div class="interpretation-tips">
                    @for (var i = 0; i < entry.InterpretationParagraphs.Count; i++)
                    {
                        var tip = entry.InterpretationParagraphs[i];
                        <div class="interpretation-tip @(i == 0 ? "tip-lead" : "tip-context")">
                            <span class="tip-bullet">✦</span>
                            <p class="tip-text">@HighlightTokens(tip)</p>
                        </div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(entry.EndpointHouseEmphasis))
                {
                    <p class="interpretation-footer">
                        <strong>Endpoint reading:</strong> @entry.EndpointHouseEmphasis
                    </p>
                }
            </section>
        }

        @* Element-establishment notes (when_established / when_not_established). *@
        @if (entry != null && (!string.IsNullOrEmpty(entry.WhenEstablished) || !string.IsNullOrEmpty(entry.WhenNotEstablished)))
        {
            <section class="detail-card kv-card">
                <h3 class="card-title">
                    <span class="card-title-icon">◎</span> Establishment
                </h3>
                <dl class="kv-grid">
                    @if (!string.IsNullOrEmpty(entry.Domain))
                    {
                        <dt>Domain</dt>
                        <dd>@entry.Domain</dd>
                    }
                    @if (!string.IsNullOrEmpty(entry.WhenEstablished))
                    {
                        <dt>When Established</dt>
                        <dd>@entry.WhenEstablished</dd>
                    }
                    @if (!string.IsNullOrEmpty(entry.WhenNotEstablished))
                    {
                        <dt>When Not Established</dt>
                        <dd>@entry.WhenNotEstablished</dd>
                    }
                </dl>
            </section>
        }

        @* Path-type interpretation tip stack — only when a specific path is selected. *@
        @if (hasPath && pathTypeEntry != null && pathTypeEntry.InterpretationParagraphs.Count > 0)
        {
            <section class="detail-card interpretation-card path-card">
                <h3 class="card-title">
                    <span class="card-title-icon">@PathTypeGlyph(Selection.Path!.PathType)</span>
                    @pathTypeEntry.Name Reading
                </h3>
                @if (!string.IsNullOrEmpty(pathTypeEntry.Tagline))
                {
                    <p class="path-type-tagline">@pathTypeEntry.Tagline</p>
                }
                @if (!string.IsNullOrEmpty(pathTypeEntry.MechanismSummary))
                {
                    <p class="path-type-mechanism">
                        <strong>How it forms.</strong> @pathTypeEntry.MechanismSummary
                    </p>
                }
                <div class="interpretation-tips">
                    @for (var i = 0; i < pathTypeEntry.InterpretationParagraphs.Count; i++)
                    {
                        var tip = pathTypeEntry.InterpretationParagraphs[i];
                        <div class="interpretation-tip @(i == 0 ? "tip-lead" : "tip-context")">
                            <span class="tip-bullet">@PathTypeGlyph(Selection.Path!.PathType)</span>
                            <p class="tip-text">@HighlightTokens(tip)</p>
                        </div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(pathTypeEntry.CoReads))
                {
                    <p class="interpretation-footer">
                        <strong>Co-reads:</strong> @pathTypeEntry.CoReads
                    </p>
                }
            </section>
        }

        @* Raw calculator notes — collapsible audit trail for power users. *@
        @if (Selection.Way.Notes is { Count: > 0 })
        {
            <section class="detail-card notes-card">
                <h3 class="card-title notes-title" @onclick="ToggleNotes" role="button">
                    <span class="card-title-icon">@(_notesExpanded ? "▾" : "▸")</span>
                    Calculator Notes
                    <span class="notes-count">(@Selection.Way.Notes.Count)</span>
                </h3>
                @if (_notesExpanded)
                {
                    <ul class="mechanism-list">
                        @foreach (var note in Selection.Way.Notes)
                        {
                            <li class="mechanism-item">
                                <span class="mechanism-bullet">›</span>
                                <span class="mechanism-text">@HighlightTokens(note)</span>
                            </li>
                        }
                    </ul>
                }
            </section>
        }
    }
</div>

@code {
    [Parameter] public WayOfPointsSelection? Selection { get; set; }
    [Parameter] public HouseChartModel? Chart { get; set; }
    [Parameter] public List<WayOfPointsElementEntry>? Elements { get; set; }
    [Parameter] public List<WayOfPointsPathTypeEntry>? PathTypes { get; set; }

    private bool _notesExpanded;

    private void ToggleNotes() => _notesExpanded = !_notesExpanded;

    // Reset the expand-notes state any time the parent passes a new selection.
    protected override void OnParametersSet()
    {
        // Default to collapsed on every selection change so power-user notes
        // don't dominate the panel for a casual user clicking through.
        _notesExpanded = false;
    }

    // ----- Theming + lookup -----
    private string PanelStyle()
    {
        if (Selection == null) return string.Empty;
        var entry = LookupElement(Selection.ElementId);
        var color = entry?.ColorHint ?? FallbackColor(Selection.ElementId);
        return $"--wop-element-color: {color};";
    }

    private WayOfPointsElementEntry? LookupElement(string key)
        => Elements?.FirstOrDefault(e => string.Equals(e.Element, key, StringComparison.OrdinalIgnoreCase));

    private WayOfPointsPathTypeEntry? LookupPathType(string id)
        => PathTypes?.FirstOrDefault(p => string.Equals(p.Id, id, StringComparison.OrdinalIgnoreCase));

    // ----- Path graph -----
    private record PathNode(string Role, string Position, string Figure, string Css);

    private List<PathNode> BuildPathNodes(WayOfPointsPathModel path)
    {
        var nodes = new List<PathNode>();
        if (path.Houses == null || path.Houses.Count == 0) return nodes;

        for (var i = 0; i < path.Houses.Count; i++)
        {
            var h = path.Houses[i];
            var role = ResolveRole(h, i, path.Houses.Count);
            var position = h >= 1 && h <= 12 ? $"H{h} {GetLatinHouseName(h)}" : GetPositionLabel(h);
            var figure = GetFigureName(h);
            var css = i == 0 ? "is-start" : (i == path.Houses.Count - 1 ? "is-end" : "is-middle");
            nodes.Add(new PathNode(role, position, figure, css));
        }
        return nodes;
    }

    private static string ResolveRole(int houseNumber, int index, int total)
    {
        if (houseNumber == 0) return "Judge";
        if (houseNumber == 13) return "Right Witness";
        if (houseNumber == 14) return "Left Witness";
        if (houseNumber >= 1 && houseNumber <= 4) return "Mother";
        if (houseNumber >= 5 && houseNumber <= 8) return "Daughter";
        if (houseNumber >= 9 && houseNumber <= 12) return "Niece";
        return $"House {houseNumber}";
    }

    private string GetPositionLabel(int houseNumber) => houseNumber switch
    {
        0 => "Judge",
        13 => "Right Witness",
        14 => "Left Witness",
        _ => $"House {houseNumber}"
    };

    private string GetFigureName(int houseNumber)
    {
        if (Chart == null) return string.Empty;
        if (houseNumber == 0)  return Chart.Judge?.Name ?? string.Empty;
        if (houseNumber == 13) return Chart.RightWitness?.Name ?? string.Empty;
        if (houseNumber == 14) return Chart.LeftWitness?.Name ?? string.Empty;
        if (houseNumber >= 1 && houseNumber <= 12)
        {
            var house = Chart.Houses?.FirstOrDefault(h => h.HouseNumber == houseNumber);
            return house?.Figure?.Name ?? string.Empty;
        }
        return string.Empty;
    }

    private string EndpointPill(WayOfPointsPathModel path)
        => $"H{path.EndpointHouse} {GetLatinHouseName(path.EndpointHouse)}";

    private static string RowLabel(int row) => row switch
    {
        1 => "Mothers/Daughters",
        2 => "Nieces",
        _ => "—"
    };

    // ----- Path-type styling helpers -----
    private static string PathTypeShort(string pathType) => pathType switch
    {
        "Strong" => "Strong",
        "StrongPassive" => "Strong Passive",
        "WeakerPassive" => "Weaker Passive",
        "Passive" => "Passive",
        _ => pathType
    };

    private static string PathTypeFallback(string pathType) => PathTypeShort(pathType) + " Path";

    private static string PathTypeGlyph(string pathType) => pathType switch
    {
        "Strong" => "★",
        "StrongPassive" => "◆",
        "WeakerPassive" => "▫",
        "Passive" => "◯",
        _ => "•"
    };

    private static string PathTypeChipClass(string pathType) => pathType switch
    {
        "Strong" => "pill-strong",
        "StrongPassive" => "pill-strong-passive",
        "WeakerPassive" => "pill-weaker-passive",
        "Passive" => "pill-passive",
        _ => "pill-unknown"
    };

    // ----- Element-key fallbacks (for charts that load before the directory does) -----
    private static string FallbackGlyph(string key) => key switch
    {
        "Fire" => "\uD83D\uDD25",
        "Air" => "\uD83D\uDCA8",
        "Water" => "\uD83D\uDCA7",
        "Earth" => "\uD83C\uDF31",
        _ => "•"
    };

    private static string FallbackLatin(string key) => key switch
    {
        "Fire" => "Via Puncti Ignis",
        "Air" => "Via Puncti Aeris",
        "Water" => "Via Puncti Aquae",
        "Earth" => "Via Puncti Terrae",
        _ => key
    };

    private static string FallbackColor(string key) => key switch
    {
        "Fire" => "#e74c3c",
        "Air" => "#f1c40f",
        "Water" => "#3498db",
        "Earth" => "#2ecc71",
        _ => "#7e57c2"
    };

    // ----- Token highlighting (lifted from PerfectionDetailPanel) -----
    private static readonly Regex HouseRegex = new Regex(@"\b(?:H|house\s+)(\d{1,2})\b", RegexOptions.IgnoreCase);
    private static readonly HashSet<string> KnownFigures = new(StringComparer.OrdinalIgnoreCase)
    {
        "Populus", "Via", "Albus", "Coniunctio", "Puella", "Amissio", "Fortuna Major", "Fortuna Minor",
        "Puer", "Rubeus", "Acquisitio", "Laetitia", "Tristitia", "Carcer", "Caput Draconis", "Cauda Draconis"
    };

    private MarkupString HighlightTokens(string text)
    {
        if (string.IsNullOrEmpty(text)) return new MarkupString(string.Empty);
        var escaped = System.Net.WebUtility.HtmlEncode(text);

        // Highlight house references like "H4" or "house 4".
        escaped = HouseRegex.Replace(escaped, m =>
        {
            var num = m.Groups[1].Value;
            return $"<span class=\"token-house\">H{num}</span>";
        });

        // Highlight known figure names.
        foreach (var fig in KnownFigures)
        {
            var pattern = $@"\b{Regex.Escape(fig)}\b";
            escaped = Regex.Replace(escaped, pattern, $"<span class=\"token-figure\">{fig}</span>", RegexOptions.IgnoreCase);
        }
        return new MarkupString(escaped);
    }

    // ----- Latin house names (matches the dictionary used elsewhere in the workspace) -----
    private static readonly Dictionary<int, string> LatinHouseNames = new()
    {
        { 1, "Vita" }, { 2, "Lucrum" }, { 3, "Fratres" }, { 4, "Genitor" },
        { 5, "Nati" }, { 6, "Valetudo" }, { 7, "Uxor" }, { 8, "Mors" },
        { 9, "Itineris" }, { 10, "Regnum" }, { 11, "Benefacta" }, { 12, "Carcer" }
    };

    private static string GetLatinHouseName(int houseNumber)
        => LatinHouseNames.TryGetValue(houseNumber, out var name) ? name : $"House {houseNumber}";
}
