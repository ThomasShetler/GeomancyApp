@* One Interactive Server boundary for sidebar + page body so Scoped services
   (e.g. ThemeService) resolve to a single instance per circuit. Without this,
   ThemeToggleButton and /workspace each lived in their own island and had
   separate ThemeService instances — theme appeared to "revert" on navigation. *@
@rendermode InteractiveServer

@ChildContent

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
