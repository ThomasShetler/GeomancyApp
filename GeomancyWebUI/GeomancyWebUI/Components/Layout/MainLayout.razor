@inherits LayoutComponentBase

<InteractiveShell>
    <div class="page">
        <div class="sidebar">
            <NavMenu />
        </div>

        <main>
            <article class="content px-4">
                @Body
            </article>
        </main>
    </div>
</InteractiveShell>

@code {
    // Theme: wwwroot/theme.js applies data-theme; NavMenu toggle + pages share
    // one Scoped ThemeService inside InteractiveShell (see InteractiveShell.razor).
}

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
